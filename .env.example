# ThreeFour (TF) - Office Time Tracker Configuration
# Copy this file to .env and update with your settings

# ==============================================================================
# REQUIRED CONFIGURATION
# ==============================================================================

# Office Wi-Fi Configuration (REQUIRED)
# This MUST match your office WiFi name exactly (case-sensitive)
OFFICE_WIFI_NAME=YourOfficeWiFiName

# MongoDB Configuration (REQUIRED)
# Get your connection string from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Example: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=your_mongodb_connection_string
MONGODB_DATABASE=wifi-calculator

# ==============================================================================
# WORK DURATION SETTINGS
# ==============================================================================

# Target work hours per day (e.g., 4 = 4 hours)
WORK_DURATION_HOURS=4

# Buffer time added to target (e.g., 10 = 4 hours + 10 minutes = 4h 10m)
BUFFER_MINUTES=10

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Server bind address (keep as 127.0.0.1 for security - localhost only)
SERVER_HOST=127.0.0.1

# Web server port (8787 avoids conflicts with common dev ports)
SERVER_PORT=8787

# ==============================================================================
# SESSION MANAGEMENT
# ==============================================================================

# Grace period for WiFi reconnection before ending session (minutes)
# If WiFi disconnects briefly (e.g., network hiccup), session continues
# Set to 0 to end session immediately on disconnect
GRACE_PERIOD_MINUTES=2

# ==============================================================================
# TIMEZONE CONFIGURATION
# ==============================================================================

# Your local timezone (for accurate time display)
# Common values: Asia/Kolkata (IST), America/New_York, Europe/London, etc.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
USER_TIMEZONE=Asia/Kolkata

# ==============================================================================
# CHECK INTERVALS (in seconds)
# ==============================================================================

# How often to check WiFi connection (30 = every 30 seconds)
WIFI_CHECK_INTERVAL_SECONDS=30

# How often to update timer and MongoDB (60 = every minute)
TIMER_CHECK_INTERVAL_SECONDS=60

# How often to check internet connectivity (captive portal detection)
CONNECTIVITY_CHECK_INTERVAL_SECONDS=30

# ==============================================================================
# TESTING MODE
# ==============================================================================

# Enable test mode for quick validation (uses 2-minute target instead of 4 hours)
# Set to true for testing, false for production use
TEST_MODE=false

# Target duration when TEST_MODE=true (in minutes)
TEST_DURATION_MINUTES=2

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable file logging (logs to LOG_FILE_PATH)
LOG_TO_FILE=false

# Log file location (when LOG_TO_FILE=true)
LOG_FILE_PATH=logs/app.log

# ==============================================================================
# DATA DIRECTORY PATHS (Legacy - for file storage fallback)
# ==============================================================================

# Primary data directory (used for gamification.json)
DATA_DIR=data

# Archive directory for rotated log files (legacy)
ARCHIVE_DIR=data/archive
